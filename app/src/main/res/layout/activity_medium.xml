<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_holder"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.fossify.commons.views.MyViewPager
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <include
        android:id="@+id/bottom_actions"
        layout="@layout/bottom_actions" />

    <!-- Elderly-friendly viewer bottom bar (docs/elderly-spec/photo-viewer.md). Shown instead of
         bottom_actions above for items opened from the "Photos" grid; the camera-review /
         external ACTION_VIEW entry points are left on the original bottom_actions UI. -->
    <LinearLayout
        android:id="@+id/photos_viewer_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/elderly_bottom_bar_padding"
        android:paddingVertical="@dimen/elderly_bottom_bar_padding"
        android:visibility="gone"
        tools:visibility="visible">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/photos_viewer_delete_button"
            style="@style/ElderlyButton.Secondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/small_margin"
            android:text="@string/delete"
            app:icon="@drawable/ic_delete_vector" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/photos_viewer_share_button"
            style="@style/ElderlyButton.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/small_margin"
            android:text="@string/share"
            app:icon="@drawable/ic_share_ios_vector" />
    </LinearLayout>

    <ImageView
        android:id="@+id/top_shadow"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:minHeight="@dimen/default_status_action_height"
        android:layout_alignBottom="@id/medium_viewer_appbar"
        android:layout_alignParentTop="true"
        android:background="@drawable/gradient_background_flipped"
        android:contentDescription="@null" />

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/medium_viewer_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@android:color/transparent"
        android:elevation="0dp"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/medium_viewer_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:menu="@menu/menu_viewpager"
            app:navigationIcon="@drawable/ic_arrow_left_vector" />

    </com.google.android.material.appbar.AppBarLayout>
</RelativeLayout>
