<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/share_contact_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:minHeight="@dimen/elderly_contact_row_min_height"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/normal_margin"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/activity_margin">

        <ImageView
            android:id="@+id/share_contact_avatar"
            android:layout_width="@dimen/elderly_contact_avatar_size"
            android:layout_height="@dimen/elderly_contact_avatar_size"
            android:contentDescription="@null"
            tools:src="@drawable/ic_person_vector" />

        <org.fossify.commons.views.MyTextView
            android:id="@+id/share_contact_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/activity_margin"
            android:textSize="@dimen/elderly_body_text_size"
            tools:ignore="RtlSymmetry"
            tools:text="Harvard" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/divider_height"
        android:background="@color/divider_grey" />
</LinearLayout>
