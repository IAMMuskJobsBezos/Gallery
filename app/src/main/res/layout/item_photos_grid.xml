<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/photos_grid_item_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <org.fossify.commons.views.MySquareImageView
        android:id="@+id/photos_grid_thumbnail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:src="@mipmap/ic_launcher" />

    <ImageView
        android:id="@+id/photos_grid_play_badge"
        android:layout_width="@dimen/elderly_play_badge_size"
        android:layout_height="@dimen/elderly_play_badge_size"
        android:layout_centerInParent="true"
        android:background="@drawable/darkened_automatic_circle_background"
        android:contentDescription="@null"
        android:padding="@dimen/small_margin"
        android:src="@drawable/ic_play_vector"
        android:visibility="gone"
        tools:visibility="visible" />

    <ImageView
        android:id="@+id/photos_grid_selection_circle"
        android:layout_width="@dimen/elderly_selection_circle_size"
        android:layout_height="@dimen/elderly_selection_circle_size"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="@dimen/medium_margin"
        android:background="@drawable/circle_outline_background"
        android:contentDescription="@null"
        android:padding="@dimen/tiny_margin"
        android:visibility="gone"
        tools:src="@drawable/ic_check_vector"
        tools:visibility="visible" />
</RelativeLayout>
