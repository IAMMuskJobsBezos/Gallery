<resources>

    <style name="AppTheme" parent="AppTheme.Base" />

    <style name="CustomBottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
    </style>

    <style name="CustomBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="FullScreenTheme.Base" parent="AppTheme">
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

    <style name="FullScreenTheme" parent="FullScreenTheme.Base" />

    <!-- Elderly-scale full-width/paired pill buttons, see docs/elderly-spec/design-principles.md.
         Mirrors the Clock app's ElderlyButton styles for a consistent look across the redesigned
         Fossify apps. -->
    <style name="ElderlyButton" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">@dimen/elderly_button_height</item>
        <item name="android:textSize">@dimen/elderly_button_text_size</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/material_dialog_corner_radius</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">@dimen/normal_margin</item>
    </style>

    <!-- Primary/confirming action: Select Photos, Delete, Yes -->
    <style name="ElderlyButton.Primary">
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="iconTint">?attr/colorOnPrimary</item>
    </style>

    <!-- Secondary/leaving action: Share, Cancel, No -->
    <style name="ElderlyButton.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/elderly_button_height</item>
        <item name="android:textSize">@dimen/elderly_button_text_size</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/material_dialog_corner_radius</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">@dimen/normal_margin</item>
        <item name="strokeColor">?attr/colorPrimary</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="iconTint">?attr/colorPrimary</item>
    </style>

    <!-- The "Photos" header label - shared by the grid header (activity_media.xml TextViews use
         this dimen directly) and the viewer toolbar title (applied in code via
         ViewPagerActivity.setupElderlyMode()) so both are guaranteed to render identically. -->
    <style name="TextAppearance.ElderlyHeader" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textSize">@dimen/elderly_header_text_size</item>
        <item name="android:textStyle">normal</item>
    </style>

</resources>
